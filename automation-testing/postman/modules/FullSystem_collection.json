{
  "info": {
    "name": "SIGAP-Laravel - Full System API Tests",
    "description": "Automated API testing for KAK, Kegiatan, and LPJ modules.\n\nPrerequisites:\n- Laravel app running at {{base_url}}\n- Database seeded with UserSeeder + MasterDataSeeder",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login sebagai Pengusul",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login berhasil', function() {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 302]);",
                  "});",
                  "",
                  "const html = pm.response.text();",
                  "const csrfMatch = html.match(/meta\\s+name=\"csrf-token\"\\s+content=\"([^\"]+)\"/);",
                  "if (csrfMatch) {",
                  "    pm.collectionVariables.set('csrf_token', csrfMatch[1]);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "{{pengusul_username}}" },
                { "key": "password", "value": "{{pengusul_password}}" },
                { "key": "_token", "value": "{{csrf_token}}" }
              ]
            },
            "url": "{{base_url}}/login"
          }
        }
      ]
    },
    {
      "name": "KAK Module",
      "item": [
        {
          "name": "KAK-FT-014 - List KAK dengan Filter Status",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code 200', function() { pm.response.to.have.status(200); });",
                  "pm.test('Response mengandung data KAK', function() {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.props.kaks.data).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Requested-With", "value": "XMLHttpRequest" }
            ],
            "url": {
              "raw": "{{base_url}}/kak?status=2",
              "host": ["{{base_url}}"],
              "path": ["kak"],
              "query": [{ "key": "status", "value": "2" }]
            }
          }
        }
      ]
    },
    {
      "name": "LPJ Module",
      "item": [
        {
          "name": "LPJ-F-010 - Pencarian Nama Kegiatan di LPJ",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code 200', function() { pm.response.to.have.status(200); });",
                  "pm.test('Filter search bekerja', function() {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.props.kegiatans).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Requested-With", "value": "XMLHttpRequest" }
            ],
            "url": {
              "raw": "{{base_url}}/lpj?search=Workshop",
              "host": ["{{base_url}}"],
              "path": ["lpj"],
              "query": [{ "key": "search", "value": "Workshop" }]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "csrf_token", "value": "" }
  ]
}

{
  "info": {
    "name": "SIGAP-Laravel - Full System API Tests",
    "description": "Automated API testing for KAK, Kegiatan, and LPJ modules.\n\nPrerequisites:\n- Laravel app running at {{base_url}}\n- Database seeded with UserSeeder + MasterDataSeeder",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login sebagai Pengusul",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login berhasil', function() {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.token).to.not.be.undefined;",
                  "    pm.collectionVariables.set('auth_token', jsonData.token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": JSON.stringify({
                "username": "{{pengusul_username}}",
                "password": "{{pengusul_password}}"
              })
            },
            "url": "{{base_url}}/api/login"
          }
        }
      ]
    },
    {
      "name": "KAK Module",
      "item": [
        {
          "name": "KAK-FT-014 - List KAK dengan Filter Status",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code 200', function() { pm.response.to.have.status(200); });",
                  "pm.test('Response mengandung data KAK', function() {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/kak?status=2",
              "host": ["{{base_url}}"],
              "path": ["api", "kak"],
              "query": [{ "key": "status", "value": "2" }]
            }
          }
        }
      ]
    },
    {
      "name": "LPJ Module",
      "item": [
        {
          "name": "LPJ-F-010 - Pencarian Nama Kegiatan di LPJ",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code 200', function() { pm.response.to.have.status(200); });",
                  "pm.test('Filter search bekerja', function() {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/lpj?search=Workshop",
              "host": ["{{base_url}}"],
              "path": ["api", "lpj"],
              "query": [{ "key": "search", "value": "Workshop" }]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "csrf_token", "value": "" }
  ]
}

{
  "info": {
    "name": "SIGAP-Laravel - Ajukan Kegiatan API Tests",
    "description": "Automated API testing for Ajukan Kegiatan feature (AK-F-001 ~ AK-F-012).\n\nCovers: Validation, Authorization, XSS Prevention at the API layer.\n\nPrerequisites:\n- Laravel app running at {{base_url}}\n- Database seeded with UserSeeder + MasterDataSeeder",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Login sebagai Pengusul",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Verify successful login",
              "pm.test('Login berhasil - redirect ke dashboard', function() {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 302]);",
              "});",
              "",
              "// Save CSRF token and cookies for subsequent requests",
              "const html = pm.response.text();",
              "const csrfMatch = html.match(/name=\"_token\"\\s+value=\"([^\"]+)\"/);",
              "if (csrfMatch) {",
              "    pm.collectionVariables.set('csrf_token', csrfMatch[1]);",
              "}",
              "",
              "// Also try meta tag",
              "const metaCsrf = html.match(/meta\\s+name=\"csrf-token\"\\s+content=\"([^\"]+)\"/);",
              "if (metaCsrf) {",
              "    pm.collectionVariables.set('csrf_token', metaCsrf[1]);",
              "}",
              "",
              "pm.test('CSRF token retrieved', function() {",
              "    const token = pm.collectionVariables.get('csrf_token');",
              "    pm.expect(token).to.be.a('string');",
              "    pm.expect(token.length).to.be.greaterThan(0);",
              "});"
            ]
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// First, get the CSRF token from the login page",
              "pm.sendRequest({",
              "    url: pm.collectionVariables.get('base_url') + '/login',",
              "    method: 'GET'",
              "}, function(err, res) {",
              "    const html = res.text();",
              "    const csrfMatch = html.match(/name=\"_token\"\\s+value=\"([^\"]+)\"/);",
              "    if (csrfMatch) {",
              "        pm.collectionVariables.set('csrf_token', csrfMatch[1]);",
              "    }",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/x-www-form-urlencoded" },
          { "key": "Accept", "value": "text/html" }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            { "key": "username", "value": "{{pengusul_username}}" },
            { "key": "password", "value": "{{pengusul_password}}" },
            { "key": "_token", "value": "{{csrf_token}}" }
          ]
        },
        "url": "{{base_url}}/login"
      }
    },
    {
      "name": "AK-F-001 - Validasi Field Wajib (penanggung_jawab kosong)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code 422 (Validation Error)', function() {",
              "    pm.expect(pm.response.code).to.be.oneOf([302, 422]);",
              "});",
              "",
              "pm.test('Response mengandung error penanggung_jawab', function() {",
              "    const body = pm.response.text();",
              "    const hasError = body.includes('penanggung_jawab') || body.includes('wajib diisi') || body.includes('required');",
              "    pm.expect(hasError).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Accept", "value": "application/json" },
          { "key": "X-Requested-With", "value": "XMLHttpRequest" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "kak_id", "value": "1" },
            { "key": "penanggung_jawab_manual", "value": "" },
            { "key": "pelaksana_manual", "value": "Jane Doe" },
            { "key": "_token", "value": "{{csrf_token}}" }
          ]
        },
        "url": "{{base_url}}/kegiatan"
      }
    },
